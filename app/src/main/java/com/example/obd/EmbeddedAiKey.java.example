package com.example.obd;

import java.nio.charset.StandardCharsets;

/**
 * Template for the bundled Gemini API key.
 *
 * <p>Copy this file to {@code EmbeddedAiKey.java} in the same directory and
 * replace {@link #CIPHER} with your own XOR-obfuscated bytes. The real file
 * is git-ignored — never commit a live key to source control.
 *
 * <h3>How to generate your own CIPHER array</h3>
 *
 * <pre>
 * python3 -c "
 * key = 'PASTE_YOUR_GEMINI_KEY_HERE'
 * pad = 'OttoCoPilotDriveSafeAndSmartWithAi'
 * out = [b ^ ord(pad[i % len(pad)]) for i, b in enumerate(key.encode())]
 * print(', '.join('(byte) 0x%02X' % b for b in out))"
 * </pre>
 *
 * Paste the resulting bytes into {@link #CIPHER}, keep the {@link #pad}
 * unchanged (unless you also updated the Python snippet), and rebuild.
 *
 * <h3>Security caveat</h3>
 *
 * This is <b>obfuscation, not encryption</b>. Anything embedded in an Android
 * APK can be recovered by a moderately skilled reverse engineer in minutes.
 * The real defence against runaway billing is the per-device monthly quota
 * in {@link AiSettings#tryConsumeFreeCall(android.content.Context)}, plus
 * (long-term) a backend proxy that hides the key entirely. See
 * {@code memory/project_ai_estimator.md} for the migration plan.
 */
final class EmbeddedAiKey {

    /**
     * Placeholder cipher. Replace with your own bytes (see class Javadoc for
     * the one-line Python snippet that generates them). Leaving the placeholder
     * in place lets the project compile, but every AI call will fail with
     * "AI unavailable" until you paste in a real key.
     */
    private static final byte[] CIPHER = {
            // 42 zero bytes = valid template that yields the empty string
            // once XOR'd with the pad. Replace with real cipher bytes.
    };

    /** Pad is built from char codes at runtime so it doesn't appear as a literal string. */
    private static byte[] pad() {
        int[] codes = {
                79, 116, 116, 111, 67, 111, 80, 105, 108, 111, 116,
                68, 114, 105, 118, 101, 83, 97, 102, 101,
                65, 110, 100, 83, 109, 97, 114, 116,
                87, 105, 116, 104, 65, 105
        };
        byte[] out = new byte[codes.length];
        for (int i = 0; i < codes.length; i++) out[i] = (byte) codes[i];
        return out;
    }

    /** Decode the bundled key on demand. Result is never cached in a static field. */
    static String get() {
        if (CIPHER.length == 0) return "";
        byte[] p = pad();
        byte[] out = new byte[CIPHER.length];
        for (int i = 0; i < CIPHER.length; i++) {
            out[i] = (byte) (CIPHER[i] ^ p[i % p.length]);
        }
        return new String(out, StandardCharsets.UTF_8);
    }

    private EmbeddedAiKey() {}
}
