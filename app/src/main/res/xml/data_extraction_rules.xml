<?xml version="1.0" encoding="utf-8"?><!--
   Backup/transfer rules for API 31+ (older devices use backup_rules.xml).
   Same policy for cloud backup and device-to-device transfer: prefs may
   travel, but the Room DB (VIN, scan reports) and every log file in the
   external files dir (diag logs, obd-events.log with VIN + GPS fixes,
   crash reports) stay on this device.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="obd.db"/>
        <exclude domain="database" path="obd.db-wal"/>
        <exclude domain="database" path="obd.db-shm"/>
        <exclude domain="external" path="."/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="obd.db"/>
        <exclude domain="database" path="obd.db-wal"/>
        <exclude domain="database" path="obd.db-shm"/>
        <exclude domain="external" path="."/>
    </device-transfer>
</data-extraction-rules>
