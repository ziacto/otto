<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surfaceBase"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SERVICE FUNCTIONS"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ISTA-style functions for your E65 730li. All operations pause normal polling, run the routine, then resume."
            android:textColor="#B0B0B0"
            android:textSize="12sp"
            android:paddingBottom="14dp" />

        <!-- 1. MODULE IDENTIFICATION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="14dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔎  Module Identification"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reads exact BMW part numbers, software/hardware version, and VIN from DME / DSC / EGS. Use this when ordering replacement parts."
                android:textColor="#C8C8C8"
                android:textSize="12sp"
                android:paddingTop="4dp"
                android:paddingBottom="10dp" />

            <Button
                android:id="@+id/btnReadIds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Read all module IDs"
                android:backgroundTint="#03DAC5"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/idResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFB300"
                android:textSize="11sp"
                android:typeface="monospace"
                android:paddingTop="10dp" />
        </LinearLayout>

        <!-- 2. CBS RESET -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="14dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🛢  CBS Service Reset"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reset oil service / brake fluid / brake pads counter on DME after maintenance. WARNING: only do this AFTER the work is actually done."
                android:textColor="#C8C8C8"
                android:textSize="12sp"
                android:paddingTop="4dp"
                android:paddingBottom="10dp" />

            <Spinner
                android:id="@+id/cbsItemSpinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnResetCbs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reset selected counter"
                android:backgroundTint="#FFB300"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/cbsResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFB300"
                android:textSize="11sp"
                android:paddingTop="8dp" />
        </LinearLayout>

        <!-- 3. BATTERY REGISTRATION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="14dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔋  Battery Registration"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tell the IBS the new battery's capacity + chemistry. Critical after replacement — otherwise alternator under-charges."
                android:textColor="#C8C8C8"
                android:textSize="12sp"
                android:paddingTop="4dp"
                android:paddingBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp">
                <EditText
                    android:id="@+id/batteryAh"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Capacity (Ah)"
                    android:inputType="number"
                    android:text="90"
                    android:textColorHint="#808080"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp" />
                <Spinner
                    android:id="@+id/batteryType"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
            </LinearLayout>

            <Button
                android:id="@+id/btnRegisterBattery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Register battery"
                android:backgroundTint="#FFB300"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/batteryResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFB300"
                android:textSize="11sp"
                android:paddingTop="8dp" />
        </LinearLayout>

        <!-- 4. CAN SNIFFER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="14dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📡  CAN Sniffer"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Capture raw D-CAN frames from the bus. Saves to /sdcard/Android/data/com.example.obd/files/diag/can_capture_*.txt for offline analysis."
                android:textColor="#C8C8C8"
                android:textSize="12sp"
                android:paddingTop="4dp"
                android:paddingBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <Button
                    android:id="@+id/btnStartSniffer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Start"
                    android:backgroundTint="#4CAF50"
                    android:textColor="#000000"
                    android:layout_marginEnd="4dp" />
                <Button
                    android:id="@+id/btnStopSniffer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Stop"
                    android:backgroundTint="#F44336"
                    android:textColor="#FFFFFF"
                    android:enabled="false" />
            </LinearLayout>

            <TextView
                android:id="@+id/snifferStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Idle"
                android:textColor="#FFB300"
                android:textSize="11sp"
                android:typeface="monospace"
                android:paddingTop="8dp" />
        </LinearLayout>

        <!-- Safety footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠ Service writes (CBS reset, battery registration) modify the DME's persistent memory. Run with engine OFF + ignition ON. Reads (Module ID, sniffer) are passive and safe."
            android:textColor="#FF6B6B"
            android:textSize="11sp"
            android:padding="10dp"
            android:gravity="center" />
    </LinearLayout>
</ScrollView>
