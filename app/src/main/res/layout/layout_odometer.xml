<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surfaceBase"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ODOMETER"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="E65 KOMBI total odometer is on K-CAN and unreachable from OBD. Below are the 3 best approximations the app can offer."
            android:textColor="#B0B0B0"
            android:textSize="12sp"
            android:paddingBottom="14dp" />

        <!-- App-tracked odometer (always works) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="14dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📱  APP-TRACKED DISTANCE"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Integrates vehicle speed over time. Most accurate over the long run."
                android:textColor="#C8C8C8"
                android:textSize="11sp"
                android:paddingTop="2dp"
                android:paddingBottom="10dp" />

            <TextView
                android:id="@+id/odoAppTracked"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0 km"
                android:textColor="#FFB300"
                android:textSize="32sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnOdoReset"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Reset to 0"
                    android:backgroundTint="#F44336"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btnOdoSeed"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Seed from cluster"
                    android:backgroundTint="#03DAC5"
                    android:textColor="#000000"
                    android:layout_marginStart="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Distance since codes cleared -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="14dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🧹  DISTANCE SINCE LAST DTC CLEAR"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OBD-II Mode 01 PID 0x31. Resets every time you clear fault codes. Useful: confirm a repair stayed clean for X km."
                android:textColor="#C8C8C8"
                android:textSize="11sp"
                android:paddingTop="2dp"
                android:paddingBottom="10dp" />

            <TextView
                android:id="@+id/odoSinceCleared"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="— km"
                android:textColor="#FFB300"
                android:textSize="32sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingBottom="6dp" />

            <Button
                android:id="@+id/btnOdoRefreshSc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Read from car"
                android:backgroundTint="#03DAC5"
                android:textColor="#000000" />
        </LinearLayout>

        <!-- BMW UDS attempt -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="14dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔬  BMW UDS DME READ (EXPERIMENTAL)"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tries BMW UDS DID 0xA001 on the DME. May or may not respond depending on your DME variant — N52 DMEs vary."
                android:textColor="#C8C8C8"
                android:textSize="11sp"
                android:paddingTop="2dp"
                android:paddingBottom="10dp" />

            <TextView
                android:id="@+id/odoUds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#FFB300"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingBottom="6dp" />

            <Button
                android:id="@+id/btnOdoRefreshUds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Try BMW UDS read"
                android:backgroundTint="#FFB300"
                android:textColor="#000000" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
