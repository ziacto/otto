<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05060B"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Header bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="BMW 730li · N52B30"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:id="@+id/gaugeStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Disconnected"
                android:textColor="#FF6E6E"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Warning lights row -->
        <com.example.obd.WarningLightsView
            android:id="@+id/warningLights"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg_accent"
            android:layout_marginBottom="10dp" />

        <!-- Action buttons: Read DTCs / Clear / VIN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="10dp">

            <!-- AppCompatButton (not <Button>) avoids MaterialButton's tinted
                 background + 6dp top/bottom insets that distort the pill shape. -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnGaugeDtc"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/btn_pill_amber"
                android:text="READ DTCs"
                android:textColor="#000000"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:includeFontPadding="false"
                android:stateListAnimator="@null"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnGaugeClear"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                android:background="@drawable/btn_pill_red"
                android:text="CLEAR DTCs"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:includeFontPadding="false"
                android:stateListAnimator="@null"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnGaugeVin"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/btn_pill_teal"
                android:text="READ VIN"
                android:textColor="#000000"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:includeFontPadding="false"
                android:stateListAnimator="@null"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp" />
        </LinearLayout>

        <!-- Action result chip -->
        <TextView
            android:id="@+id/gaugeActionResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:padding="10dp"
            android:text=""
            android:textSize="11sp"
            android:textColor="#FFD600"
            android:fontFamily="monospace"
            android:visibility="gone"
            android:layout_marginBottom="10dp" />

        <!-- Tap-to-info hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ⓘ  Tap any gauge for details on what it measures"
            android:textColor="#80FFFFFF"
            android:textSize="10sp"
            android:gravity="center"
            android:paddingBottom="6dp" />

        <!-- Hero gauges row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.example.obd.CircularGaugeView
                android:id="@+id/gaugeRpm"
                android:layout_width="0dp"
                android:layout_height="220dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true" />

            <com.example.obd.CircularGaugeView
                android:id="@+id/gaugeSpeed"
                android:layout_width="0dp"
                android:layout_height="220dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Small circular gauges row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.example.obd.CircularGaugeView
                android:id="@+id/gaugeLoad"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true" />

            <com.example.obd.CircularGaugeView
                android:id="@+id/gaugeThrottle"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_weight="1"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Bar gauges -->
        <com.example.obd.BarGaugeView
            android:id="@+id/gaugeCoolant"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginBottom="6dp"
            android:clickable="true"
            android:focusable="true" />

        <com.example.obd.BarGaugeView
            android:id="@+id/gaugeOil"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginBottom="6dp"
            android:clickable="true"
            android:focusable="true" />

        <com.example.obd.BarGaugeView
            android:id="@+id/gaugeIntake"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginBottom="6dp"
            android:clickable="true"
            android:focusable="true" />

        <com.example.obd.BarGaugeView
            android:id="@+id/gaugeFuel"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Battery + Odometer mini-cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/cardBattery"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_bg_accent"
                android:padding="12dp"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔋 BATTERY"
                    android:textColor="#03DAC5"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/gaugeBattery"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingTop="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="volts"
                    android:textColor="#B0B0B0"
                    android:textSize="10sp"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardOdometer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_bg_accent"
                android:padding="12dp"
                android:layout_marginStart="6dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📍 ODOMETER"
                    android:textColor="#03DAC5"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15" />

                <TextView
                    android:id="@+id/gaugeOdometer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingTop="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="km tracked"
                    android:textColor="#B0B0B0"
                    android:textSize="10sp"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
