<?xml version="1.0" encoding="utf-8"?>
<!--
    Live Data browser: scrollable list of EVERY known sensor with its current
    value, status pill (OK/WARN/OUT), description, and BMW-specific note.
    Category chips across the top filter the list.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surfaceBase"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LIVE DATA"
        android:textAppearance="@style/Text.Section"
        android:paddingBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap any row for full description, normal range, and BMW notes."
        android:textColor="@color/textSecondary"
        android:textSize="11sp"
        android:paddingBottom="8dp" />

    <!-- Category filter chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/liveCategoryChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="6dp" />
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/surfaceStroke"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="6dp" />

    <!-- Sensor rows -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/liveRowContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>
</LinearLayout>
