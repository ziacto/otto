<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- Header strip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="HUD · 730li N52B30"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.15" />

            <TextView
                android:id="@+id/hudStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● OFFLINE"
                android:textColor="#FF6E6E"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.10" />
        </LinearLayout>

        <!-- Shift lights bar -->
        <com.example.obd.ShiftLightsView
            android:id="@+id/hudShiftLights"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginBottom="8dp" />

        <!-- Big centre RPM readout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_accent"
            android:gravity="center"
            android:padding="14dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ENGINE SPEED"
                android:textColor="#03DAC5"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.30" />

            <TextView
                android:id="@+id/hudRpm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="88sp"
                android:textStyle="bold"
                android:fontFeatureSettings="tnum"
                android:includeFontPadding="false"
                android:shadowColor="#9903DAC5"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="20" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="rpm"
                android:textColor="#B0B0B0"
                android:textSize="12sp"
                android:letterSpacing="0.2" />
        </LinearLayout>

        <!-- Speed + Gear + Throttle row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:orientation="vertical"
                android:background="@drawable/card_bg_accent"
                android:padding="14dp"
                android:gravity="center"
                android:layout_marginEnd="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SPEED"
                    android:textColor="#03DAC5"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.30" />

                <TextView
                    android:id="@+id/hudSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    android:fontFeatureSettings="tnum"
                    android:includeFontPadding="false"
                    android:shadowColor="#9903DAC5"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="15" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="km/h"
                    android:textColor="#B0B0B0"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Gear indicator -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_bg_accent"
                android:padding="14dp"
                android:gravity="center"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GEAR"
                    android:textColor="#03DAC5"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.20" />

                <TextView
                    android:id="@+id/hudGear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="N"
                    android:textColor="#888888"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:fontFeatureSettings="tnum"
                    android:includeFontPadding="false"
                    android:shadowColor="#9903DAC5"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="12" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="est."
                    android:textColor="#555555"
                    android:textSize="9sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@drawable/card_bg_accent"
                android:padding="14dp"
                android:gravity="center"
                android:layout_marginStart="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="THROTTLE"
                    android:textColor="#03DAC5"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.20" />

                <TextView
                    android:id="@+id/hudThrottle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    android:fontFeatureSettings="tnum"
                    android:includeFontPadding="false"
                    android:shadowColor="#99FFB300"
                    android:shadowDx="0"
                    android:shadowDy="0"
                    android:shadowRadius="12" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="%"
                    android:textColor="#B0B0B0"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Mini stat strip (2 rows of 3 cells) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <include layout="@layout/hud_mini_cell" android:id="@+id/hudCellCoolant" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <include layout="@layout/hud_mini_cell" android:id="@+id/hudCellOil" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <include layout="@layout/hud_mini_cell" android:id="@+id/hudCellMaf" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <include layout="@layout/hud_mini_cell" android:id="@+id/hudCellLoad" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <include layout="@layout/hud_mini_cell" android:id="@+id/hudCellIntake" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <include layout="@layout/hud_mini_cell" android:id="@+id/hudCellBattery" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 3: Timing / Torque / Lambda -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <include layout="@layout/hud_mini_cell" android:id="@+id/hudCellTiming" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <include layout="@layout/hud_mini_cell" android:id="@+id/hudCellTorque" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <include layout="@layout/hud_mini_cell" android:id="@+id/hudCellLambda" />
            </LinearLayout>
        </LinearLayout>

        <!-- Fuel health panel: STFT / LTFT / Ambient -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_accent"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◐  FUEL HEALTH"
                android:textColor="#03DAC5"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.25"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SHORT TRIM"
                        android:textColor="#888888"
                        android:textSize="9sp"
                        android:letterSpacing="0.15" />
                    <TextView
                        android:id="@+id/hudStft"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFeatureSettings="tnum" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="%"
                        android:textColor="#555555"
                        android:textSize="9sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LONG TRIM"
                        android:textColor="#888888"
                        android:textSize="9sp"
                        android:letterSpacing="0.15" />
                    <TextView
                        android:id="@+id/hudLtft"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFeatureSettings="tnum" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="%"
                        android:textColor="#555555"
                        android:textSize="9sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AMBIENT"
                        android:textColor="#888888"
                        android:textSize="9sp"
                        android:letterSpacing="0.15" />
                    <TextView
                        android:id="@+id/hudAmbient"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFeatureSettings="tnum" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="°C"
                        android:textColor="#555555"
                        android:textSize="9sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Performance / session panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_accent"
            android:padding="12dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◐  THIS SESSION"
                android:textColor="#03DAC5"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.25"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PEAK RPM"
                        android:textColor="#888888"
                        android:textSize="9sp"
                        android:letterSpacing="0.15" />
                    <TextView
                        android:id="@+id/hudPeakRpm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFeatureSettings="tnum" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PEAK SPEED"
                        android:textColor="#888888"
                        android:textSize="9sp"
                        android:letterSpacing="0.15" />
                    <TextView
                        android:id="@+id/hudPeakSpeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFeatureSettings="tnum" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DISTANCE"
                        android:textColor="#888888"
                        android:textSize="9sp"
                        android:letterSpacing="0.15" />
                    <TextView
                        android:id="@+id/hudSessionDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFeatureSettings="tnum" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="INSTANT FUEL"
                        android:textColor="#888888"
                        android:textSize="9sp"
                        android:letterSpacing="0.15" />
                    <TextView
                        android:id="@+id/hudInstantFuel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#03DAC5"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFeatureSettings="tnum" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AVG FUEL"
                        android:textColor="#888888"
                        android:textSize="9sp"
                        android:letterSpacing="0.15" />
                    <TextView
                        android:id="@+id/hudAvgFuel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFB300"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFeatureSettings="tnum" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DURATION"
                        android:textColor="#888888"
                        android:textSize="9sp"
                        android:letterSpacing="0.15" />
                    <TextView
                        android:id="@+id/hudSessionDuration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:00"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFeatureSettings="tnum" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Module status grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_accent"
            android:padding="10dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="◐  D-CAN MODULES"
                    android:textColor="#03DAC5"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.25" />

                <Button
                    android:id="@+id/hudScanModules"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="SCAN"
                    android:textColor="#000000"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.10"
                    android:background="@drawable/btn_pill_teal"
                    android:minWidth="60dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <com.example.obd.ModuleStatusGridView
                android:id="@+id/hudModuleGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Bottom action row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/hudResetSession"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="RESET SESSION"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:background="@drawable/btn_pill_red"
                android:layout_marginEnd="4dp"
                android:minWidth="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/hudReadDtcs"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="READ DTCs"
                android:textColor="#000000"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:background="@drawable/btn_pill_amber"
                android:layout_marginStart="4dp"
                android:minWidth="0dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- Action result chip -->
        <TextView
            android:id="@+id/hudActionResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:padding="10dp"
            android:text=""
            android:textSize="11sp"
            android:textColor="#FFD600"
            android:fontFamily="monospace"
            android:visibility="gone"
            android:layout_marginTop="8dp" />
    </LinearLayout>
</ScrollView>
