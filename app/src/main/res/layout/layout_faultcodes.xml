<?xml version="1.0" encoding="utf-8"?>
<!--
    Diagnose · Scan tab. Redesigned as a single dark "console" card: a primary
    Run Full Scan action, a 2×3 grid of read-mode tiles (icon + title + hint),
    a destructive Clear outline, BMW-module scans (DSC/EGS), and a share action.
    The tiles are plain clickable LinearLayouts — FaultCodesController holds them
    as View[] and toggles setEnabled(), so no Button cast is required.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surfaceBase"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Main console card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/diag_card_bg"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fault Codes (DTC) &amp; Diagnostics"
                android:textSize="21sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="@color/textPrimary" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="OBD-II Modes 01/02/03/04/07/09/0A — engine ECU only. DSC/ABS/airbag/transmission need BMW-specific tools."
                android:textSize="12sp"
                android:textColor="@color/textSecondary"
                android:paddingTop="4dp"
                android:paddingBottom="16dp"
                android:lineSpacingExtra="2dp" />

            <!-- Primary action -->
            <LinearLayout
                android:id="@+id/btnFullScan"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_pill_blue"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/ic_pulse_circle" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Run Full Scan"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- Grid row 1: Stored / Pending / Permanent -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:id="@+id/btnReadStored"
                    style="@style/DiagTile"
                    android:layout_marginEnd="6dp">
                    <ImageView style="@style/DiagTileIcon" android:src="@drawable/ic_diag_doc" />
                    <TextView style="@style/DiagTileTitle" android:text="Stored" />
                    <TextView style="@style/DiagTileHint" android:text="View stored DTCs" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnReadPending"
                    style="@style/DiagTile"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp">
                    <ImageView style="@style/DiagTileIcon" android:src="@drawable/ic_diag_clock" />
                    <TextView style="@style/DiagTileTitle" android:text="Pending" />
                    <TextView style="@style/DiagTileHint" android:text="View pending DTCs" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnReadPermanent"
                    style="@style/DiagTile"
                    android:layout_marginStart="6dp">
                    <ImageView style="@style/DiagTileIcon" android:src="@drawable/ic_diag_warn" />
                    <TextView style="@style/DiagTileTitle" android:text="Permanent" />
                    <TextView style="@style/DiagTileHint" android:text="View permanent DTCs" />
                </LinearLayout>
            </LinearLayout>

            <!-- Grid row 2: Freeze Frame / Readiness / ECU Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/btnFreezeFrame"
                    style="@style/DiagTile"
                    android:layout_marginEnd="6dp">
                    <ImageView style="@style/DiagTileIcon" android:src="@drawable/ic_diag_snowflake" />
                    <TextView style="@style/DiagTileTitle" android:text="Freeze Frame" />
                    <TextView style="@style/DiagTileHint" android:text="View freeze frame data" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnReadiness"
                    style="@style/DiagTile"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp">
                    <ImageView style="@style/DiagTileIcon" android:src="@drawable/ic_diag_checklist" />
                    <TextView style="@style/DiagTileTitle" android:text="Readiness" />
                    <TextView style="@style/DiagTileHint" android:text="I/M readiness status" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnEcuInfo"
                    style="@style/DiagTile"
                    android:layout_marginStart="6dp">
                    <ImageView style="@style/DiagTileIcon" android:src="@drawable/ic_diag_chip" />
                    <TextView style="@style/DiagTileTitle" android:text="ECU Info" />
                    <TextView style="@style/DiagTileHint" android:text="View ECU information" />
                </LinearLayout>
            </LinearLayout>

            <!-- Destructive: clear stored codes -->
            <LinearLayout
                android:id="@+id/btnClearDtcs"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_outline_red"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/ic_trash"
                    android:tint="#FF6B6B" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Clear Stored Codes (Mode 04)"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FF6B6B" />
            </LinearLayout>

            <!-- BMW-specific module scans -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:id="@+id/btnScanDsc"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/btn_outline_blue"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_diag_dsc" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Scan DSC"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#DCE6F5" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnScanEgs"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/btn_outline_blue"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ic_diag_egs" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Scan EGS"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#DCE6F5" />
                </LinearLayout>
            </LinearLayout>

            <!-- Share -->
            <LinearLayout
                android:id="@+id/btnShareReport"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_outline_blue"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_diag_share" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Share Mechanic Report"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#4FB4EF" />
            </LinearLayout>
        </LinearLayout>

        <!-- Info / live result card. Starts with helper copy; fills with scan output. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/diag_card_bg"
            android:padding="16dp"
            android:layout_marginTop="14dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_diag_info"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="2dp" />

            <ScrollView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="120dp"
                android:scrollbars="none">

                <TextView
                    android:id="@+id/tvDtcResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/textSecondary"
                    android:textSize="13sp"
                    android:lineSpacingExtra="3dp"
                    android:text="" />
            </ScrollView>
        </LinearLayout>

        <!-- Kept for back-compat with existing controller code; hidden. -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnReadVin"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:text="VIN" />
    </LinearLayout>
</ScrollView>
