<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/darkBackground"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fault Codes (DTC) &amp; Diagnostics"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/accentColor"
        android:paddingBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="OBD-II Modes 01/02/03/04/07/09/0A — engine ECU only. DSC/ABS/airbag/transmission need BMW-specific tools."
        android:textSize="11sp"
        android:textColor="@color/secondaryTextColor"
        android:paddingBottom="8dp" />

    <Button
        android:id="@+id/btnFullScan"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Run Full Scan"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="@color/accentColor"
        android:textColor="#000000"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="6dp">

        <Button
            android:id="@+id/btnReadStored"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Stored"
            android:backgroundTint="@color/accentColor"
            android:textColor="#000000" />

        <Button
            android:id="@+id/btnReadPending"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="Pending"
            android:backgroundTint="#FFD600"
            android:textColor="#000000" />

        <Button
            android:id="@+id/btnReadPermanent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Permanent"
            android:backgroundTint="#FF7043"
            android:textColor="#000000" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="6dp">

        <Button
            android:id="@+id/btnFreezeFrame"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Freeze Frame"
            android:backgroundTint="#9575CD"
            android:textColor="#000000" />

        <Button
            android:id="@+id/btnReadiness"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="Readiness"
            android:backgroundTint="#4FC3F7"
            android:textColor="#000000" />

        <Button
            android:id="@+id/btnEcuInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="ECU Info"
            android:backgroundTint="#03DAC5"
            android:textColor="#000000" />
    </LinearLayout>

    <Button
        android:id="@+id/btnClearDtcs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clear Stored Codes (Mode 04)"
        android:backgroundTint="#F44336"
        android:textColor="#FFFFFF"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">
        <Button
            android:id="@+id/btnScanDsc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Scan DSC"
            android:textSize="12sp"
            android:backgroundTint="#7E57C2"
            android:textColor="#FFFFFF" />
        <Button
            android:id="@+id/btnScanEgs"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Scan EGS"
            android:textSize="12sp"
            android:backgroundTint="#7E57C2"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <Button
        android:id="@+id/btnShareReport"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Share Mechanic Report"
        android:textSize="13sp"
        android:backgroundTint="#03DAC5"
        android:textColor="#000000"
        android:layout_marginBottom="12dp" />

    <!-- Kept for back-compat with existing controller code; hidden so UI stays clean. -->
    <Button
        android:id="@+id/btnReadVin"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:text="VIN" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1A1A2E"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvDtcResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E0E0E0"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:text="" />
    </ScrollView>

</LinearLayout>
