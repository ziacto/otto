<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101820">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <!-- Fuel Pressure Card -->
        <LinearLayout
            android:id="@+id/cardFuelPressure"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fuel Pressure"
                android:textSize="18sp"
                android:textColor="#A0A0A0"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/tvFuelPressure"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- kPa"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#FF5722"
                android:layout_gravity="center_horizontal"
                android:paddingTop="6dp" />
        </LinearLayout>

        <!-- Fuel Level Card -->
        <LinearLayout
            android:id="@+id/cardFuelLevel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fuel Level"
                android:textSize="18sp"
                android:textColor="#A0A0A0"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/tvFuelLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- %"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#00E676"
                android:layout_gravity="center_horizontal"
                android:paddingTop="6dp" />
        </LinearLayout>

        <!-- Engine Load Card -->
        <LinearLayout
            android:id="@+id/cardEngineLoad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Engine Load"
                android:textSize="18sp"
                android:textColor="#A0A0A0"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/tvEngineLoad"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- %"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#FFC107"
                android:layout_gravity="center_horizontal"
                android:paddingTop="6dp" />
        </LinearLayout>

        <!-- Lambda Card -->
        <LinearLayout
            android:id="@+id/cardLambda"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lambda"
                android:textSize="18sp"
                android:textColor="#A0A0A0"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/tvLambda"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- λ"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:layout_gravity="center_horizontal"
                android:paddingTop="6dp" />
        </LinearLayout>

        <!-- Short Term Fuel Trim Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Short Term Fuel Trim"
                android:textSize="18sp"
                android:textColor="#A0A0A0"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/tvStft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- %"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#FF7043"
                android:layout_gravity="center_horizontal"
                android:paddingTop="6dp" />
        </LinearLayout>

        <!-- Long Term Fuel Trim Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Long Term Fuel Trim"
                android:textSize="18sp"
                android:textColor="#A0A0A0"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/tvLtft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- %"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#FFA726"
                android:layout_gravity="center_horizontal"
                android:paddingTop="6dp" />
        </LinearLayout>

        <!-- Commanded Lambda Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Commanded Lambda"
                android:textSize="18sp"
                android:textColor="#A0A0A0"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/tvCommandedLambda"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- λ"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#AB47BC"
                android:layout_gravity="center_horizontal"
                android:paddingTop="6dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
