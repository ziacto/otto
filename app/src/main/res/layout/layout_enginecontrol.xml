<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#101820">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <!-- RPM Card -->
        <LinearLayout
            android:id="@+id/cardRpm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Engine RPM"
                android:textSize="18sp"
                android:textColor="#A0A0A0"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/tvRpm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- 1/min"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#FF3D00"
                android:layout_gravity="center_horizontal"
                android:paddingTop="6dp" />
        </LinearLayout>

        <!-- MAF Card -->
        <LinearLayout
            android:id="@+id/cardMassAirFlow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mass Air Flow"
                android:textSize="18sp"
                android:textColor="#A0A0A0"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/tvMassAirFlow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- g/s"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#00B0FF"
                android:layout_gravity="center_horizontal"
                android:paddingTop="6dp" />
        </LinearLayout>

        <!-- Boost Card -->
        <LinearLayout
            android:id="@+id/cardBoost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Boost Pressure"
                android:textSize="18sp"
                android:textColor="#A0A0A0"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/tvBoost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- bar"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#FFC400"
                android:layout_gravity="center_horizontal"
                android:paddingTop="6dp" />
        </LinearLayout>

        <!-- Throttle Card -->
        <LinearLayout
            android:id="@+id/cardThrottle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Throttle Position"
                android:textSize="18sp"
                android:textColor="#A0A0A0"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/tvThrottle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- %"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#FFEA00"
                android:layout_gravity="center_horizontal"
                android:paddingTop="6dp" />
        </LinearLayout>

        <!-- Actual Torque Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Actual Torque"
                android:textSize="18sp"
                android:textColor="#A0A0A0"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/tvEngineTorque"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- %"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#FF6D00"
                android:layout_gravity="center_horizontal"
                android:paddingTop="6dp" />
        </LinearLayout>

        <!-- Demand Torque Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Demand Torque"
                android:textSize="18sp"
                android:textColor="#A0A0A0"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/tvDemandTorque"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- %"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#FF8F00"
                android:layout_gravity="center_horizontal"
                android:paddingTop="6dp" />
        </LinearLayout>

        <!-- Accelerator Pedal Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Accelerator Pedal"
                android:textSize="18sp"
                android:textColor="#A0A0A0"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:id="@+id/tvAccelPedal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-- %"
                android:textSize="42sp"
                android:textStyle="bold"
                android:textColor="#69F0AE"
                android:layout_gravity="center_horizontal"
                android:paddingTop="6dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
