<?xml version="1.0" encoding="utf-8"?>
<!--
    One-page Welcome. Everything fits above the fold on a typical 6" phone:
    brand mark, car illustration, connect card, and a 2x2 feature grid of
    what the app does. Extra prose lives in the drawer sections it points to.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_hero"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp">

        <!-- Brand -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"
            android:letterSpacing="0.05"
            android:layout_gravity="center_horizontal" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:letterSpacing="0.22"
            android:text="@string/app_tagline"
            android:textColor="@color/bmwBlau"
            android:textSize="11sp"
            android:paddingBottom="6dp" />

        <!-- Real 3D PBR render of a BMW M4 F82 (bundled GLB, ~23 MB) via
             SceneView / Filament. Continuously rotated + bobs + nods; see
             CarHeroSceneView.kt for the animation composition. -->
        <com.example.obd.CarHeroSceneView
            android:id="@+id/imgWelcomeCar"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="6dp" />

        <!-- Connection status + primary Connect button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg_accent"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvWelcomeStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="● Not connected"
                android:textColor="#FF6E6E"
                android:textSize="12sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingBottom="8dp" />

            <Button
                android:id="@+id/btnWelcomeConnect"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/btn_pill_teal"
                android:text="CONNECT TO CAR"
                android:textColor="#000000"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:stateListAnimator="@null" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Plug in the ELM327 · ignition on · we'll walk you through it"
                android:textColor="#B0B0B0"
                android:textSize="10sp"
                android:gravity="center"
                android:paddingTop="6dp" />
        </LinearLayout>

        <!-- 2x2 feature grid — same content as the old scrolling cards,
             collapsed to a compact glance. Titles first, one-line body. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="10dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📡  Live data"
                    android:textColor="@color/textPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Animated engine, tile dashboard, warning lights."
                    android:textColor="@color/textSecondary"
                    android:textSize="10sp"
                    android:lineSpacingExtra="1dp"
                    android:paddingTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="10dp"
                android:layout_marginStart="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🩺  Fault codes"
                    android:textColor="@color/textPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="DME, DSC, EGS scans + BMW-specific causes."
                    android:textColor="@color/textSecondary"
                    android:textSize="10sp"
                    android:lineSpacingExtra="1dp"
                    android:paddingTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="10dp"
                android:layout_marginEnd="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🤖  AI estimator"
                    android:textColor="@color/textPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Photo → Dubai-priced repair + chat follow-up."
                    android:textColor="@color/textSecondary"
                    android:textSize="10sp"
                    android:lineSpacingExtra="1dp"
                    android:paddingTop="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_bg"
                android:padding="10dp"
                android:layout_marginStart="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗂  Garage"
                    android:textColor="@color/textPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Trips, CBS, 30-day trends, CSV export."
                    android:textColor="@color/textSecondary"
                    android:textSize="10sp"
                    android:lineSpacingExtra="1dp"
                    android:paddingTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No paywall · No accounts · Local-only data"
            android:textColor="@color/bmwBlau"
            android:textSize="10sp"
            android:textStyle="italic"
            android:gravity="center"
            android:paddingTop="10dp" />
    </LinearLayout>
</ScrollView>
