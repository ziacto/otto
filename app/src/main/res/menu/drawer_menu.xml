<?xml version="1.0" encoding="utf-8"?>
<!--
    Drawer menu. Primary destinations live on the bottom nav (Drive / Diagnose /
    Garage). The drawer holds Live Data browsing plus less-frequent screens.
    Live Data is a single entry — the car-system category (Powertrain, Thermal,
    Fuel & Air, …) is chosen in-screen via the chips at the top, which also swap
    the OBD poll group so only that system's PIDs are polled.
-->
<menu xmlns:android="http://schemas.android.com/apk/res/android">

    <group android:checkableBehavior="single">
        <item
            android:id="@+id/nav_welcome"
            android:title="Welcome" />
        <item
            android:id="@+id/nav_dashboard"
            android:title="Drive" />
        <item
            android:id="@+id/nav_odometer"
            android:title="Odometer" />
        <item
            android:id="@+id/nav_faultcodes"
            android:title="Diagnose" />
        <!-- "Car & Sensors" (the interactive car-anatomy diagram) is no longer a
             drawer entry: it is reached from a launcher card at the top of the
             Live Data screen, since both are about sensors. See openCarDiagram()
             in MainActivity. -->
        <item
            android:id="@+id/nav_garage"
            android:title="Garage" />
    </group>

    <group android:checkableBehavior="single">
        <item
            android:id="@+id/nav_live_all"
            android:title="Live Data" />
    </group>

    <group android:checkableBehavior="single">
        <item
            android:id="@+id/nav_analytics"
            android:title="Trends" />
        <item
            android:id="@+id/nav_sprint"
            android:title="0–100 Timer" />
        <item
            android:id="@+id/nav_knowledge"
            android:title="Knowledge Base" />
        <item
            android:id="@+id/nav_service"
            android:title="Service Functions" />
        <item
            android:id="@+id/nav_ai_estimator"
            android:title="AI Repair Estimator" />
        <item
            android:id="@+id/nav_car_advisor"
            android:title="Help Me Buy a Car" />
        <!-- "Scan Reports" is no longer its own drawer entry: it is now the
             "History" tab inside the Diagnose hub (nav_faultcodes), alongside the
             "Scan" (Fault Codes) tab. Full Scans still save there. -->
    </group>

    <item
        android:id="@+id/nav_debuglog"
        android:title="Debug Log" />
    <!-- Simulator Mode + Run Self-Test removed from the drawer (end users don't
         need them). Both still work headlessly via the debug intents (action
         extra "simulator" / "selftest") handled in MainActivity.handleDebugIntent(). -->
    <item
        android:id="@+id/nav_fuel_probe"
        android:title="Probe Fuel Level (BMW UDS)" />
    <item
        android:id="@+id/nav_clear_data"
        android:title="Clear Data (logs &amp; cache)" />
    <item
        android:id="@+id/nav_bt_reset"
        android:title="Reset Bluetooth Pairing" />
    <item
        android:id="@+id/nav_disconnect"
        android:title="Disconnect" />
    <!-- Settings intentionally omitted — there's no screen yet. Add the item back
         and the matching handler in MainActivity when a settings screen ships. -->

</menu>
