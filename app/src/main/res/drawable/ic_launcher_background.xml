<?xml version="1.0" encoding="utf-8"?>
<!--
  CarSense AI adaptive icon background.
  Vertical-diagonal gradient from near-black indigo to deep teal, evoking a
  premium dashboard at night. The radial glow sits where the foreground gauge
  arc renders, lifting the centre of the icon out of the dark frame.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path android:pathData="M0,0 h108 v108 h-108 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0" android:startY="0"
                android:endX="108" android:endY="108"
                android:startColor="#0A1929"
                android:endColor="#0F3D4F" />
        </aapt:attr>
    </path>

    <path android:pathData="M54,54 m-44,0 a44,44 0 1,0 88,0 a44,44 0 1,0 -88,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54" android:centerY="54"
                android:gradientRadius="44"
                android:startColor="#1A5C7A"
                android:endColor="#0A1929" />
        </aapt:attr>
    </path>
</vector>
