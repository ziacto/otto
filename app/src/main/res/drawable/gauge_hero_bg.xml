<?xml version="1.0" encoding="utf-8"?>
<!-- Deep-teal → indigo gradient behind hero RPM/Speed gauges. Reads as one
     continuous glass panel across the two cards. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="135"
        android:startColor="#173B4E"
        android:centerColor="#122236"
        android:endColor="#0D1524" />
    <corners android:radius="18dp" />
    <stroke android:width="1dp" android:color="#1F4A72" />
</shape>
