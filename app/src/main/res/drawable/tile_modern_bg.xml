<?xml version="1.0" encoding="utf-8"?>
<!-- Soft gradient tile background used by tile_metric.xml.
     Slightly warmer top → cooler bottom so tiles have a light source direction. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="#1B1E2C"
        android:endColor="#12141F" />
    <corners android:radius="16dp" />
    <stroke android:width="1dp" android:color="#242A3D" />
</shape>
