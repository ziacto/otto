<?xml version="1.0" encoding="utf-8"?>
<!-- BMW-Blau-accented card. Used on the hero RPM / Speed gauges and any tile
     we want to read as "primary live channel". -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="135"
        android:startColor="#1F3A55"
        android:endColor="#0E1A2A" />
    <corners android:radius="14dp" />
    <stroke android:width="1dp" android:color="@color/bmwBlau" />
</shape>
