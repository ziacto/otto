<?xml version="1.0" encoding="utf-8"?>
<!-- Primary action pill — BMW-blue glass gradient. Matches the unified action
     row on the Drive dashboard (READ DTCs / CLEAR DTCs / READ VIN). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="135"
        android:startColor="#2E6FB7"
        android:endColor="#173E63" />
    <corners android:radius="16dp" />
    <stroke android:width="1dp" android:color="#3E7FC4" />
</shape>
