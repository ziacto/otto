<?xml version="1.0" encoding="utf-8"?>
<!--
  Otto adaptive icon foreground.

  Design: a stylized "O" gauge dial with an animated-looking needle pointing
  up-right and a small AI sparkle in the upper-right quadrant. The "O" doubles
  as the brand letter and a speedometer. Built entirely with vector paths so it
  scales crisply from 48px launcher to 512px Play Store hero.

  Safe zone: launchers crop foregrounds to the inner 66dp (centred). All
  meaningful art stays within roughly x=21..87, y=21..87.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Soft outer glow: makes the gauge feel illuminated against any background -->
    <path
        android:pathData="M54,54 m-32,0 a32,32 0 1,0 64,0 a32,32 0 1,0 -64,0"
        android:fillColor="#1A03DAC5" />

    <!-- Main "O" gauge ring (stroked, cyan with subtle vertical gradient) -->
    <path
        android:pathData="M54,54 m-28,0 a28,28 0 1,0 56,0 a28,28 0 1,0 -56,0 z M54,54 m-22,0 a22,22 0 1,1 44,0 a22,22 0 1,1 -44,0 z"
        android:fillType="evenOdd">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="26"
                android:endX="54" android:endY="82"
                android:startColor="#5FF1FF"
                android:endColor="#03DAC5" />
        </aapt:attr>
    </path>

    <!-- Tick marks around the gauge — 5 short ticks at the bottom arc -->
    <path android:pathData="M34,67 L36,65" android:strokeWidth="1.6" android:strokeColor="#03DAC5" android:strokeLineCap="round" />
    <path android:pathData="M40,73 L42,70.5" android:strokeWidth="1.6" android:strokeColor="#03DAC5" android:strokeLineCap="round" />
    <path android:pathData="M54,76 L54,73" android:strokeWidth="1.6" android:strokeColor="#03DAC5" android:strokeLineCap="round" />
    <path android:pathData="M66,70.5 L68,73" android:strokeWidth="1.6" android:strokeColor="#03DAC5" android:strokeLineCap="round" />
    <path android:pathData="M72,65 L74,67" android:strokeWidth="1.6" android:strokeColor="#03DAC5" android:strokeLineCap="round" />

    <!-- Needle — bold diagonal from the centre pointing up-right (positive direction) -->
    <path
        android:pathData="M54,54 L72,38"
        android:strokeWidth="3.2"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />
    <!-- Needle pivot dot -->
    <path
        android:pathData="M54,54 m-3.5,0 a3.5,3.5 0 1,0 7,0 a3.5,3.5 0 1,0 -7,0"
        android:fillColor="#FFFFFF" />
    <path
        android:pathData="M54,54 m-1.6,0 a1.6,1.6 0 1,0 3.2,0 a1.6,1.6 0 1,0 -3.2,0"
        android:fillColor="#0A1929" />

    <!-- AI sparkle (4-point star) in the upper-right corner — telegraphs the AI angle -->
    <path
        android:pathData="M84,24 L86,30 L92,32 L86,34 L84,40 L82,34 L76,32 L82,30 Z"
        android:fillColor="#FFD600" />
    <!-- Tiny halo around the sparkle -->
    <path
        android:pathData="M84,32 m-9,0 a9,9 0 1,0 18,0 a9,9 0 1,0 -18,0"
        android:fillColor="#22FFD600" />
</vector>
