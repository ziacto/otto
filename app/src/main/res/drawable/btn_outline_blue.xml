<?xml version="1.0" encoding="utf-8"?>
<!-- Secondary action button — Scan DSC / Scan EGS / Share Mechanic Report.
     Subtle blue-tinted panel with a blue hairline. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#1E3352" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#3E7FC4" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="135" android:startColor="#152540" android:endColor="#0D1526" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#274063" />
        </shape>
    </item>
</selector>
