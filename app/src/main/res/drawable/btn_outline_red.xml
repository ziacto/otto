<?xml version="1.0" encoding="utf-8"?>
<!-- Destructive outline button — "Clear Stored Codes". Transparent-ish fill, red edge. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#33F44336" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#F44336" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:angle="135" android:startColor="#1AF44336" android:endColor="#0D160F" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#8A3A34" />
        </shape>
    </item>
</selector>
