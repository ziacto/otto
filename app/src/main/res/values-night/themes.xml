<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Base.Theme.OBD" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Background color for dark mode (dark grey or black) -->
        <item name="android:windowBackground">@color/darkBackground</item>

        <!-- Text color for dark mode (light grey or white) -->
        <item name="android:textColorPrimary">@color/primaryTextColor</item>
        <item name="android:textColorSecondary">@color/secondaryTextColor</item>

        <!-- Primary accent color for dark mode -->
        <item name="colorPrimary">@color/darkPrimary</item>
        <item name="colorPrimaryVariant">@color/darkPrimaryVariant</item>
        <item name="colorSecondary">@color/darkSecondary</item>

        <!-- Accent color for buttons and other UI elements -->
        <item name="colorAccent">@color/accentColor</item>

        <!-- ActionBar / Toolbar color for dark mode -->
        <item name="android:statusBarColor">@color/darkPrimary</item>

    </style>
</resources>
